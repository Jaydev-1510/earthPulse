---

---

<div class="fixed w-screen h-screen top-0 left-0 z-0">
  <canvas id="ep-globe"></canvas>
</div>

<script>
  import * as THREE from "three";
  import type {
    EpFlyToPayload,
    EpLayerPayload,
    EpDataPayload,
    EpSelectPayload,
    Earthquake,
    Volcano,
    ISSState,
    LayerId,
  } from "../types/index";

  const GLOBE_RADIUS = 2;
  const CAMERA_DEFAULT = 7;
  const CAMERA_MIN = 3;
  const CAMERA_MAX = 12;
  const AUTO_ROTATE_SPEED = 0.0015;
  const ISS_REFRESH_MS = 5_000;
  const EQ_REFRESH_MS = 60_000;
  const canvas = document.getElementById("ep-globe") as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });

  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
  camera.position.z = CAMERA_DEFAULT;

  function resize() {
    const w = canvas.parentElement?.clientWidth ?? window.innerWidth;
    const h = canvas.parentElement?.clientHeight ?? window.innerHeight;
    renderer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  }

  resize();
  window.addEventListener("resize", resize);

  function latLonToVec3(lat: number, lon: number, r: number): THREE.Vector3 {
    const phi = (90 - lat) * (Math.PI / 180);
    const theta = (lon + 180) * (Math.PI / 180);
    return new THREE.Vector3(
      -r * Math.sin(phi) * Math.cos(theta),
      r * Math.cos(phi),
      r * Math.sin(phi) * Math.sin(theta),
    );
  }

  function buildStarField(): THREE.Points {
    const geo = new THREE.BufferGeometry();
    const verts = new Float32Array(2000 * 3);
    for (let i = 0; i < verts.length; i++) {
      verts[i] = (Math.random() - 0.5) * 80;
    }
    geo.setAttribute("position", new THREE.BufferAttribute(verts, 3));
    return new THREE.Points(
      geo,
      new THREE.PointsMaterial({
        color: 0x99aacc,
        size: 0.055,
        sizeAttenuation: true,
      }),
    );
  }

  scene.add(buildStarField());

  const globeGeo = new THREE.SphereGeometry(GLOBE_RADIUS, 64, 64);
  const globeMat = new THREE.MeshPhongMaterial({
    color: 0x0a1628,
    emissive: 0x060e1a,
    specular: 0x1a3a6a,
    shininess: 30,
  });
  const globe = new THREE.Mesh(globeGeo, globeMat);

  scene.add(globe);

  const atmMesh = new THREE.Mesh(
    new THREE.SphereGeometry(GLOBE_RADIUS + 0.08, 32, 32),
    new THREE.MeshPhongMaterial({
      color: 0x1a4a8a,
      transparent: true,
      opacity: 0.07,
      side: THREE.BackSide,
    }),
  );

  scene.add(atmMesh);

  function buildGrid(): THREE.Group {
    const group = new THREE.Group();
    const mat = new THREE.LineBasicMaterial({
      color: 0x0d2040,
      transparent: true,
      opacity: 0.55,
    });

    for (let lat = -75; lat <= 75; lat += 15) {
      const pts: THREE.Vector3[] = [];
      for (let lon = 0; lon <= 360; lon += 3) {
        pts.push(latLonToVec3(lat, lon - 180, GLOBE_RADIUS + 0.003));
      }
      group.add(
        new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), mat),
      );
    }

    for (let lon = -180; lon < 180; lon += 15) {
      const pts: THREE.Vector3[] = [];
      for (let lat = -90; lat <= 90; lat += 3) {
        pts.push(latLonToVec3(lat, lon, GLOBE_RADIUS + 0.003));
      }
      group.add(
        new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), mat),
      );
    }
    return group;
  }

  const grid = buildGrid();
  const sunLight = new THREE.DirectionalLight(0x8899cc, 1.6);
  const rimLight = new THREE.DirectionalLight(0x112244, 0.6);

  scene.add(grid);
  scene.add(new THREE.AmbientLight(0x223366, 1.4));

  sunLight.position.set(5, 3, 5);
  scene.add(sunLight);

  rimLight.position.set(-5, -2, -3);
  scene.add(rimLight);

  function makeSphere(
    lat: number,
    lon: number,
    radius: number,
    color: number,
    altitude = 0.018,
  ): THREE.Mesh {
    const mesh = new THREE.Mesh(
      new THREE.SphereGeometry(radius, 10, 10),
      new THREE.MeshBasicMaterial({ color }),
    );
    mesh.position.copy(latLonToVec3(lat, lon, GLOBE_RADIUS + altitude));
    return mesh;
  }

  const groups: Record<string, THREE.Group> = {
    eq: new THREE.Group(),
    vol: new THREE.Group(),
    iss: new THREE.Group(),
    aurora: new THREE.Group(),
  };
  Object.values(groups).forEach((g) => globe.add(g));

  const EQ_COLORS: Record<string, number> = {
    low: 0x9fe1cb,
    minor: 0x1d9e75,
    moderate: 0xef9f27,
    strong: 0xe24b4a,
    major: 0xa32d2d,
  };

  function magClass(mag: number): string {
    if (mag < 2.5) return "low";
    if (mag < 4.0) return "minor";
    if (mag < 6.0) return "moderate";
    if (mag < 7.0) return "strong";
    return "major";
  }

  function magRadius(mag: number): number {
    return Math.max(0.018, Math.min(0.072, mag * 0.016));
  }

  const eqMeshes: Array<THREE.Mesh & { userData: { event: Earthquake } }> = [];

  function renderEarthquakes(quakes: Earthquake[]) {
    groups.eq.clear();
    eqMeshes.length = 0;
    quakes.forEach((eq) => {
      const cls = magClass(eq.magnitude);
      const mesh = makeSphere(
        eq.lat,
        eq.lon,
        magRadius(eq.magnitude),
        EQ_COLORS[cls],
      );
      mesh.userData = { event: eq };
      groups.eq.add(mesh);
      eqMeshes.push(mesh as any);
    });
  }

  const volMeshes: THREE.Mesh[] = [];

  function renderVolcanoes(volcanoes: Volcano[]) {
    groups.vol.clear();
    volMeshes.length = 0;
    volcanoes.forEach((v) => {
      const mesh = makeSphere(v.lat, v.lon, 0.028, 0xef9f27);
      mesh.userData = { event: v };
      groups.vol.add(mesh);
      volMeshes.push(mesh);
    });
  }

  const issMesh = makeSphere(0, 0, 0.038, 0x5dcaa5, 0.13);

  issMesh.userData = { type: "iss" };
  globe.add(issMesh);

  let issTrailLine: THREE.Line | null = null;

  function renderISS(state: ISSState) {
    const { lat, lon } = state.current;
    issMesh.position.copy(latLonToVec3(lat, lon, GLOBE_RADIUS + 0.13));

    if (issTrailLine) {
      globe.remove(issTrailLine);
      issTrailLine = null;
    }
    if (state.trail.length > 1) {
      const pts = state.trail.map((p) =>
        latLonToVec3(p.lat, p.lon, GLOBE_RADIUS + 0.13),
      );
      issTrailLine = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(pts),
        new THREE.LineBasicMaterial({
          color: 0x5dcaa5,
          transparent: true,
          opacity: 0.4,
        }),
      );
      globe.add(issTrailLine);
    }
  }

  const auroraRingN = new THREE.Mesh(
    new THREE.TorusGeometry(
      GLOBE_RADIUS * Math.cos((20 * Math.PI) / 180) * 0.94,
      0.035,
      8,
      90,
    ),
    new THREE.MeshBasicMaterial({
      color: 0x7f77dd,
      transparent: true,
      opacity: 0.3,
    }),
  );
  auroraRingN.position.y = GLOBE_RADIUS * Math.sin((70 * Math.PI) / 180);
  globe.add(auroraRingN);

  const auroraRingS = auroraRingN.clone();
  auroraRingS.position.y = -auroraRingN.position.y;
  globe.add(auroraRingS);

  let rotY = 0;
  let rotX = 0.18;
  let autoRotate = true;
  let isDragging = false;
  let prevMouse = { x: 0, y: 0 };
  let camDist = CAMERA_DEFAULT;

  interface FlyTarget {
    targetY: number;
    targetX: number;
    targetDist: number;
    frames: number;
    total: number;
  }
  let flyTarget: FlyTarget | null = null;

  function flyTo(lat: number, lon: number, zoom = 3.8) {
    const targetY = -((lon * Math.PI) / 180);
    const targetX = ((lat * Math.PI) / 180) * 0.6;
    flyTarget = { targetY, targetX, targetDist: zoom, frames: 0, total: 60 };
    autoRotate = false;
  }

  const rayCaster = new THREE.Raycaster();
  const mouse2d = new THREE.Vector2();

  function getIntersected(e: MouseEvent | Touch): THREE.Intersection | null {
    const rect = canvas.getBoundingClientRect();
    const x = "clientX" in e ? e.clientX : (e as Touch).clientX;
    const y = "clientY" in e ? e.clientY : (e as Touch).clientY;
    mouse2d.set(
      ((x - rect.left) / rect.width) * 2 - 1,
      ((y - rect.top) / rect.height) * -2 + 1,
    );
    rayCaster.setFromCamera(mouse2d, camera);
    const targets = [...eqMeshes, ...volMeshes, issMesh];
    const hits = rayCaster.intersectObjects(targets);
    return hits[0] ?? null;
  }

  const tooltip = document.createElement("div");
  tooltip.id = "ep-tooltip";
  Object.assign(tooltip.style, {
    position: "absolute",
    pointerEvents: "none",
    background: "rgba(5,12,28,0.5)",
    backdropFilter: "blur(12px)",
    border: "0.5px solid rgba(100,160,255,0.28)",
    borderRadius: "8px",
    padding: "8px 12px",
    fontSize: "12px",
    color: "#a8d0ff",
    lineHeight: "1.6",
    maxWidth: "200px",
    display: "none",
    zIndex: "50",
    fontFamily: "var(--font-mono, monospace)",
  });
  canvas.parentElement?.appendChild(tooltip);

  function showTooltip(e: MouseEvent, html: string) {
    const rect = canvas.getBoundingClientRect();
    tooltip.innerHTML = html;
    tooltip.style.display = "block";
    tooltip.style.left = e.clientX - rect.left + 14 + "px";
    tooltip.style.top = e.clientY - rect.top - 10 + "px";
  }
  function hideTooltip() {
    tooltip.style.display = "none";
  }

  function buildTooltipHtml(obj: THREE.Object3D): string {
    const d = obj.userData;
    if (!d?.event) {
      if (d?.type === "iss")
        return "<strong>ISS</strong><br>International Space Station<br>Altitude: ~408 km";
      return "";
    }
    const ev = d.event;
    if (ev.type === "earthquake") {
      return `<strong>Earthquake</strong><br>${ev.place}<br>M ${ev.magnitude.toFixed(1)} · ${ev.depth} km deep<br>${new Date(ev.time).toUTCString().slice(0, 22)}`;
    }
    if (ev.type === "volcano") {
      return `<strong>Volcano</strong><br>${ev.name}<br>${ev.country} · ${ev.region}<br>${ev.elevation.toLocaleString()} m`;
    }
    return "";
  }

  canvas.addEventListener("mousedown", (e) => {
    isDragging = true;
    autoRotate = false;
    prevMouse = { x: e.clientX, y: e.clientY };
  });

  canvas.addEventListener("mousemove", (e) => {
    if (isDragging) {
      rotY += (e.clientX - prevMouse.x) * 0.005;
      rotX += (e.clientY - prevMouse.y) * 0.003;
      rotX = Math.max(-1.3, Math.min(1.3, rotX));
      prevMouse = { x: e.clientX, y: e.clientY };
      hideTooltip();
      return;
    }
    const hit = getIntersected(e);
    if (hit) {
      canvas.style.cursor = "pointer";
      showTooltip(e, buildTooltipHtml(hit.object));
    } else {
      canvas.style.cursor = "grab";
      hideTooltip();
    }
  });

  canvas.addEventListener("mouseup", (e) => {
    if (!isDragging) return;
    const dx = e.clientX - prevMouse.x;
    const dy = e.clientY - prevMouse.y;
    if (Math.abs(dx) < 4 && Math.abs(dy) < 4) {
      const hit = getIntersected(e);
      if (hit?.object?.userData?.event) {
        window.dispatchEvent(
          new CustomEvent("ep:select", {
            detail: { event: hit.object.userData.event },
          }),
        );
      }
    }
    isDragging = false;
  });

  canvas.addEventListener("mouseleave", () => {
    isDragging = false;
    hideTooltip();
  });

  canvas.addEventListener(
    "wheel",
    (e) => {
      e.preventDefault();
      camDist = Math.max(
        CAMERA_MIN,
        Math.min(CAMERA_MAX, camDist + e.deltaY * 0.005),
      );
    },
    { passive: false },
  );

  let lastTouchDist = 0;

  canvas.addEventListener(
    "touchstart",
    (e) => {
      if (e.touches.length === 1) {
        isDragging = true;
        autoRotate = false;
        prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      }
      if (e.touches.length === 2) {
        lastTouchDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY,
        );
      }
    },
    { passive: true },
  );

  canvas.addEventListener(
    "touchmove",
    (e) => {
      if (e.touches.length === 1 && isDragging) {
        rotY += (e.touches[0].clientX - prevMouse.x) * 0.005;
        rotX += (e.touches[0].clientY - prevMouse.y) * 0.003;
        rotX = Math.max(-1.3, Math.min(1.3, rotX));
        prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
      }
      if (e.touches.length === 2) {
        const dist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY,
        );
        camDist = Math.max(
          CAMERA_MIN,
          Math.min(CAMERA_MAX, camDist - (dist - lastTouchDist) * 0.01),
        );
        lastTouchDist = dist;
      }
    },
    { passive: true },
  );

  canvas.addEventListener("touchend", () => {
    isDragging = false;
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "f" || e.key === "F") {
      rotY = 0;
      rotX = 0.18;
      camDist = CAMERA_DEFAULT;
      autoRotate = true;
    }
  });

  window.addEventListener("ep:data", (e: CustomEvent<EpDataPayload>) => {
    const { earthquakes, volcanoes, iss } = e.detail;
    renderEarthquakes(earthquakes);
    renderVolcanoes(volcanoes);
    renderISS(iss);
  });

  window.addEventListener("ep:flyto", (e: CustomEvent<EpFlyToPayload>) => {
    const { lat, lon, zoom } = e.detail;
    flyTo(lat, lon, zoom);
  });

  window.addEventListener("ep:layer", (e: CustomEvent<EpLayerPayload>) => {
    const { layer, visible } = e.detail;
    if (groups[layer]) groups[layer].visible = visible;
    if (layer === "iss") {
      issMesh.visible = visible;
      if (issTrailLine) issTrailLine.visible = visible;
    }
    if (layer === "aurora") {
      auroraRingN.visible = visible;
      auroraRingS.visible = visible;
    }
  });

  let pulseT = 0;

  function animateVolcanoPulse(dt: number) {
    pulseT += dt * 2;
    const s = 1 + Math.sin(pulseT) * 0.25;
    volMeshes.forEach((m) => m.scale.setScalar(s));
  }

  let last = performance.now();

  function animate() {
    requestAnimationFrame(animate);
    const now = performance.now();
    const dt = (now - last) / 1000;
    last = now;

    if (autoRotate) rotY += AUTO_ROTATE_SPEED;

    if (flyTarget) {
      const t = flyTarget.frames / flyTarget.total;
      const ease = 1 - Math.pow(1 - t, 3);
      rotY = rotY + (flyTarget.targetY - rotY) * ease * 0.06;
      rotX = rotX + (flyTarget.targetX - rotX) * ease * 0.06;
      camDist = camDist + (flyTarget.targetDist - camDist) * ease * 0.06;
      flyTarget.frames++;
      if (flyTarget.frames >= flyTarget.total) flyTarget = null;
    }

    globe.rotation.y = rotY;
    globe.rotation.x = rotX;
    atmMesh.rotation.copy(globe.rotation);
    camera.position.z = camDist;
    animateVolcanoPulse(dt);
    renderer.render(scene, camera);
  }

  animate();
  (window as any).__ep_globe = {
    flyTo,
    renderEarthquakes,
    renderVolcanoes,
    renderISS,
  };
</script>
